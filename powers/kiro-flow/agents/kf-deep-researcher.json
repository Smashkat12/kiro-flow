{
  "$schema": "https://github.com/smashkat12/kiro-flow/schemas/kiro-agent.schema.json",
  "name": "kf-deep-researcher",
  "description": "ruflo deep-research for Kiro — multi-angle web research with verified citations; findings persisted to claude-flow memory",
  "prompt": "file://./prompts/kf-deep-researcher.md",
  "tools": [
    "read",
    "write",
    "web_search",
    "web_fetch",
    "@claude-flow/analyze_diff",
    "@claude-flow/analyze_diff-classify",
    "@claude-flow/analyze_diff-reviewers",
    "@claude-flow/analyze_diff-risk",
    "@claude-flow/analyze_diff-stats",
    "@claude-flow/analyze_file-risk",
    "@claude-flow/embeddings_compare",
    "@claude-flow/embeddings_generate",
    "@claude-flow/embeddings_hyperbolic",
    "@claude-flow/embeddings_init",
    "@claude-flow/embeddings_neural",
    "@claude-flow/embeddings_rabitq_build",
    "@claude-flow/embeddings_rabitq_search",
    "@claude-flow/embeddings_rabitq_status",
    "@claude-flow/embeddings_search",
    "@claude-flow/embeddings_status",
    "@claude-flow/guidance_capabilities",
    "@claude-flow/guidance_discover",
    "@claude-flow/guidance_quickref",
    "@claude-flow/guidance_recommend",
    "@claude-flow/guidance_workflow",
    "@claude-flow/memory_bridge_status",
    "@claude-flow/memory_cleanup",
    "@claude-flow/memory_compress",
    "@claude-flow/memory_delete",
    "@claude-flow/memory_detailed-stats",
    "@claude-flow/memory_export",
    "@claude-flow/memory_import",
    "@claude-flow/memory_import_claude",
    "@claude-flow/memory_list",
    "@claude-flow/memory_migrate",
    "@claude-flow/memory_retrieve",
    "@claude-flow/memory_search",
    "@claude-flow/memory_search_unified",
    "@claude-flow/memory_stats",
    "@claude-flow/memory_store"
  ],
  "allowedTools": [
    "read",
    "web_search",
    "web_fetch",
    "@claude-flow/analyze_diff",
    "@claude-flow/analyze_diff-classify",
    "@claude-flow/analyze_diff-reviewers",
    "@claude-flow/analyze_diff-risk",
    "@claude-flow/analyze_diff-stats",
    "@claude-flow/analyze_file-risk",
    "@claude-flow/embeddings_compare",
    "@claude-flow/embeddings_generate",
    "@claude-flow/embeddings_hyperbolic",
    "@claude-flow/embeddings_init",
    "@claude-flow/embeddings_neural",
    "@claude-flow/embeddings_rabitq_build",
    "@claude-flow/embeddings_rabitq_search",
    "@claude-flow/embeddings_rabitq_status",
    "@claude-flow/embeddings_search",
    "@claude-flow/embeddings_status",
    "@claude-flow/guidance_capabilities",
    "@claude-flow/guidance_discover",
    "@claude-flow/guidance_quickref",
    "@claude-flow/guidance_recommend",
    "@claude-flow/guidance_workflow",
    "@claude-flow/memory_bridge_status",
    "@claude-flow/memory_cleanup",
    "@claude-flow/memory_compress",
    "@claude-flow/memory_delete",
    "@claude-flow/memory_detailed-stats",
    "@claude-flow/memory_export",
    "@claude-flow/memory_import",
    "@claude-flow/memory_import_claude",
    "@claude-flow/memory_list",
    "@claude-flow/memory_migrate",
    "@claude-flow/memory_retrieve",
    "@claude-flow/memory_search",
    "@claude-flow/memory_search_unified",
    "@claude-flow/memory_stats",
    "@claude-flow/memory_store"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "node .kiro/kiro-flow/kiro-hook-adapter.cjs session-bridge memory-inject session-restore auto-memory:import"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "node .kiro/kiro-flow/kiro-hook-adapter.cjs route"
      }
    ],
    "preToolUse": [
      {
        "matcher": "execute_bash",
        "command": "node .kiro/kiro-flow/kiro-hook-adapter.cjs pre-bash"
      },
      {
        "matcher": "fs_write",
        "command": "node .kiro/kiro-flow/kiro-hook-adapter.cjs pre-edit"
      }
    ],
    "postToolUse": [
      {
        "matcher": "fs_write",
        "command": "node .kiro/kiro-flow/kiro-hook-adapter.cjs post-edit"
      },
      {
        "matcher": "execute_bash",
        "command": "node .kiro/kiro-flow/kiro-hook-adapter.cjs post-bash"
      }
    ],
    "stop": [
      {
        "command": "node .kiro/kiro-flow/kiro-hook-adapter.cjs session-end auto-memory:sync session-bridge memory-refresh"
      }
    ]
  },
  "includeMcpJson": true
}
