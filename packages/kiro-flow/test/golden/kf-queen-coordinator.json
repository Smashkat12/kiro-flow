  "toolsSettings": {
    "subagent": {
      "availableAgents": [
        "kf-backend-dev",
        "kf-code-analyzer",
        "kf-coder",
        "kf-collective-intelligence-coordinator",
        "kf-goal-planner",
        "kf-planner",
        "kf-pr-manager",
        "kf-researcher",
        "kf-reviewer",
        "kf-swarm-memory-manager",
        "kf-tester"
      ],
      "trustedAgents": [
        "kf-backend-dev",
        "kf-code-analyzer",
        "kf-coder",
        "kf-collective-intelligence-coordinator",
        "kf-goal-planner",
        "kf-planner",
