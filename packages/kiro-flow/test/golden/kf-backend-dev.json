{
  "$schema": "https://github.com/smashkat12/kiro-flow/schemas/kiro-agent.schema.json",
  "name": "kf-backend-dev",
  "description": "Specialized agent for backend API development with self-learning and pattern recognition",
  "prompt": "file://./prompts/kf-backend-dev.md",
  "tools": [
    "read",
    "shell",
    "write",
    "@claude-flow/hooks_notify",
    "@claude-flow/hooks_post-task",
    "@claude-flow/hooks_pre-task",
    "@claude-flow/memory_bridge_status",
    "@claude-flow/memory_cleanup",
    "@claude-flow/memory_compress",
    "@claude-flow/memory_delete",
    "@claude-flow/memory_detailed-stats",
    "@claude-flow/memory_export",
    "@claude-flow/memory_import",
    "@claude-flow/memory_import_claude",
    "@claude-flow/memory_list",
    "@claude-flow/memory_migrate",
    "@claude-flow/memory_retrieve",
    "@claude-flow/memory_search",
    "@claude-flow/memory_search_unified",
    "@claude-flow/memory_stats",
    "@claude-flow/memory_store",
    "@claude-flow/progress_check",
    "@claude-flow/progress_summary",
    "@claude-flow/progress_sync",
    "@claude-flow/progress_watch",
    "@claude-flow/session_current",
    "@claude-flow/session_delete",
    "@claude-flow/session_export",
    "@claude-flow/session_import",
    "@claude-flow/session_info",
    "@claude-flow/session_list",
    "@claude-flow/session_restore",
    "@claude-flow/session_save",
    "@claude-flow/task_assign",
    "@claude-flow/task_cancel",
    "@claude-flow/task_complete",
    "@claude-flow/task_create",
    "@claude-flow/task_list",
    "@claude-flow/task_retry",
    "@claude-flow/task_status",
    "@claude-flow/task_summary",
    "@claude-flow/task_update"
  ],
  "allowedTools": [
    "read",
    "@claude-flow/hooks_notify",
    "@claude-flow/hooks_post-task",
    "@claude-flow/hooks_pre-task",
    "@claude-flow/memory_bridge_status",
    "@claude-flow/memory_cleanup",
    "@claude-flow/memory_compress",
    "@claude-flow/memory_delete",
    "@claude-flow/memory_detailed-stats",
    "@claude-flow/memory_export",
    "@claude-flow/memory_import",
    "@claude-flow/memory_import_claude",
    "@claude-flow/memory_list",
    "@claude-flow/memory_migrate",
    "@claude-flow/memory_retrieve",
    "@claude-flow/memory_search",
    "@claude-flow/memory_search_unified",
    "@claude-flow/memory_stats",
    "@claude-flow/memory_store",
    "@claude-flow/progress_check",
    "@claude-flow/progress_summary",
    "@claude-flow/progress_sync",
    "@claude-flow/progress_watch",
    "@claude-flow/session_current",
    "@claude-flow/session_delete",
    "@claude-flow/session_export",
    "@claude-flow/session_import",
    "@claude-flow/session_info",
    "@claude-flow/session_list",
    "@claude-flow/session_restore",
    "@claude-flow/session_save",
    "@claude-flow/task_assign",
    "@claude-flow/task_cancel",
    "@claude-flow/task_complete",
    "@claude-flow/task_create",
    "@claude-flow/task_list",
    "@claude-flow/task_retry",
    "@claude-flow/task_status",
    "@claude-flow/task_summary",
    "@claude-flow/task_update"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "node .kiro/kiro-flow/kiro-hook-adapter.cjs session-restore auto-memory:import"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "node .kiro/kiro-flow/kiro-hook-adapter.cjs route"
      }
    ],
    "preToolUse": [
      {
        "matcher": "execute_bash",
        "command": "node .kiro/kiro-flow/kiro-hook-adapter.cjs pre-bash"
      },
      {
        "matcher": "fs_write",
        "command": "node .kiro/kiro-flow/kiro-hook-adapter.cjs pre-edit"
      }
    ],
    "postToolUse": [
      {
        "matcher": "fs_write",
        "command": "node .kiro/kiro-flow/kiro-hook-adapter.cjs post-edit"
      },
      {
        "matcher": "execute_bash",
        "command": "node .kiro/kiro-flow/kiro-hook-adapter.cjs post-bash"
      }
    ],
    "stop": [
      {
        "command": "node .kiro/kiro-flow/kiro-hook-adapter.cjs session-end auto-memory:sync"
      }
    ]
  },
  "includeMcpJson": true
}
