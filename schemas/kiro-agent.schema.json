{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/smashkat12/kiro-flow/schemas/kiro-agent.schema.json",
  "title": "Kiro CLI custom agent configuration (.kiro/agents/*.json)",
  "description": "Hand-built from kiro.dev/docs/cli/custom-agents/configuration-reference (July 2026). Used to CI-validate artifacts generated by `kiro-flow convert`.",
  "type": "object",
  "required": ["name", "description"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "name": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9-_]*$",
      "description": "Agent identifier; kiro-flow generates kf-* prefixed names"
    },
    "description": { "type": "string", "minLength": 1 },
    "prompt": {
      "type": "string",
      "description": "Inline system prompt or file:// URI resolved relative to the agent config location"
    },
    "mcpServers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/mcpServer" }
    },
    "tools": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Built-in tool names, @server, @server/tool, or *"
    },
    "toolAliases": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "allowedTools": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Glob patterns; tools that run without prompting"
    },
    "toolsSettings": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "subagent": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "availableAgents": { "type": "array", "items": { "type": "string" } },
            "trustedAgents": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "resources": {
      "type": "array",
      "description": "Extra context files. kiro-cli 2.10.0 REQUIRES each entry be a file:// or skill:// string at chat runtime (a bare path or other scheme errors; the knowledgeBase object form is rejected — 'not valid under anyOf' — so it is NOT supported on the CLI, whatever the IDE may do). file://<path|glob> loads matching files; skill://<name> resolves to .kiro/skills/<name>/SKILL.md (and ~/.kiro/skills). Note: every .kiro/skills/*/SKILL.md already auto-loads into all agents.",
      "items": {
        "type": "string",
        "pattern": "^(file|skill)://",
        "description": "file://<path or glob> or skill://<name>"
      }
    },
    "hooks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agentSpawn": { "$ref": "#/$defs/hookList" },
        "userPromptSubmit": { "$ref": "#/$defs/hookList" },
        "preToolUse": { "$ref": "#/$defs/hookList" },
        "postToolUse": { "$ref": "#/$defs/hookList" },
        "stop": { "$ref": "#/$defs/hookList" }
      }
    },
    "includeMcpJson": { "type": "boolean" },
    "model": { "type": "string" },
    "keyboardShortcut": { "type": "string" },
    "welcomeMessage": { "type": "string" }
  },
  "$defs": {
    "mcpServer": {
      "type": "object",
      "required": ["command"],
      "additionalProperties": true,
      "properties": {
        "command": { "type": "string" },
        "args": { "type": "array", "items": { "type": "string" } },
        "env": { "type": "object", "additionalProperties": { "type": "string" } },
        "timeout": { "type": "integer", "minimum": 0 },
        "oauth": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "clientId": { "type": "string" },
            "redirectUri": { "type": "string" },
            "oauthScopes": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "hookList": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command"],
        "additionalProperties": true,
        "properties": {
          "command": { "type": "string" },
          "matcher": { "type": "string" }
        }
      }
    }
  }
}
